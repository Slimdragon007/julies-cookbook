# Julie's Cookbook — local dev env contract.
# Mirror of the env vars set as Cloudflare Pages secrets in production.
# See docs/REFERENCE.md "Env var contract" for the authoritative list.
#
# Usage: copy to .env.local in the REPO PARENT dir (one level above worktrees,
# next to the main checkout) — local builds and `npm run scrape` read from
# there, not from inside individual worktrees.

# --- Supabase (single naming scheme, Rule 5) -----------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Required at runtime (audit endpoint fails if any are missing) -------
ANTHROPIC_API_KEY=                  # Claude — recipe extraction + chat
CLOUDINARY_CLOUD_NAME=              # image hosting
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
SCRAPINGBEE_API_KEY=                # Cloudflare-bypass for scraper
INVITE_CODE=                        # gates /api/signup

# --- Optional at runtime (graceful degrade) ------------------------------
USDA_API_KEY=                       # ingredient macros (falls back to Claude → table → 0)
PEXELS_API_KEY=                     # image fallback when scrape finds none
AUDIT_SECRET=                       # gates /api/audit if set
DISCORD_WEBHOOK_URL=                # audit failure alerts
APP_URL=                            # override audit's self-check target
